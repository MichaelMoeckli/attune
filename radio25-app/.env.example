# Required for production show generation
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=

# Optional fallback voice (used when a style-specific voice is not set)
ELEVENLABS_VOICE_ID=

# Style-specific voices (override the fallback per Moderationsstil)
ELEVENLABS_VOICE_ID_FORMAL=
ELEVENLABS_VOICE_ID_CASUAL=
ELEVENLABS_VOICE_ID_ENERGETIC=

OPENWEATHERMAP_API_KEY=

# Optional — Jamendo for free music tracks
JAMENDO_CLIENT_ID=

# Optional — Spotify integration (login + Web Playback SDK)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# When 'true', skips ElevenLabs and falls back to browser Web Speech API.
# Use this for preview/dev environments to avoid burning credits.
USE_MOCK_TTS=false

# Client-visible flags (NEXT_PUBLIC_ ships to the browser bundle)
NEXT_PUBLIC_MOCK_MODE=false
NEXT_PUBLIC_SPOTIFY_ENABLED=false

# Invite-only access — required.
# DEMO_PASSWORD is the shared password guests enter on /unlock.
# DEMO_COOKIE_SECRET signs the session cookie; must be 32+ random characters
# (e.g. `openssl rand -base64 48`). Rotating it logs everyone out.
DEMO_PASSWORD=
DEMO_COOKIE_SECRET=
